# Local Environment Variables Template
# Copy this file to '.env' and fill in your values

# Google Gemini API Credentials
GEMINI_API_KEY=your_gemini_api_key_here

# Target Receiver Email (Where digests and PDFs are delivered)
RECEIVER_EMAIL=your_personal_email@example.com

# SMTP Server Login Configurations
EMAIL_SENDER=sender_email@gmail.com
SMTP_USER=sender_email@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx   # App Password if using Gmail 2FA
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Option to bypass AI resume rewriting entirely and directly receive job listings email
BYPASS_REWRITING=false
